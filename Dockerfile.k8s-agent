# Build stage – install Python dependencies
FROM python:3.12-slim AS builder

WORKDIR /build
COPY charts/k8s-agent/src/requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# Final stage
FROM python:3.12-slim

# Create non-root user
RUN groupadd -g 1000 agent && useradd -u 1000 -g agent -m agent

WORKDIR /app

# Copy pip packages from builder
COPY --from=builder /install /usr/local

# Copy source
COPY charts/k8s-agent/src/main.py .

RUN chown -R agent:agent /app

USER agent

# Run-once by default (CronJob); set SCAN_INTERVAL>0 for continuous mode
ENV SCAN_INTERVAL=0
ENV LOG_LEVEL=INFO

ENTRYPOINT ["python", "-u", "main.py"]
